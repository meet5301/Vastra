NODE_ENV=production
PORT=5001
SITE_URL=https://vastra.example.com

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/vastra-production
JWT_SECRET=replace-with-very-strong-production-secret
JWT_EXPIRE=7d

# Comma-separated list. Keep production domains only.
CORS_ORIGIN=https://vastra.example.com,https://www.vastra.example.com

AUTH_RATE_LIMIT_MAX=20
ADMIN_RATE_LIMIT_MAX=80

PAYMENT_GATEWAY_MODE=live
COD_MAX_AMOUNT=15000
COD_EXTRA_CHARGE=30