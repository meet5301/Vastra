NODE_ENV=staging
PORT=5001
SITE_URL=https://staging.vastra.example.com

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/vastra-staging
JWT_SECRET=replace-with-strong-staging-secret
JWT_EXPIRE=7d

# Comma-separated list. Keep staging domains only.
CORS_ORIGIN=https://staging.vastra.example.com

AUTH_RATE_LIMIT_MAX=25
ADMIN_RATE_LIMIT_MAX=100

PAYMENT_GATEWAY_MODE=test
COD_MAX_AMOUNT=15000
COD_EXTRA_CHARGE=30